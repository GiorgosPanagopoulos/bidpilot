ANTHROPIC_API_KEY=sk-ant-...
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/
MONGO_DB_NAME=bidpilot
CHROMA_PATH=./chroma_data
TED_API_BASE=https://api.ted.europa.eu/v3

# Matching weights (must sum to 1.0)
WEIGHT_SEMANTIC=0.6
WEIGHT_RULE=0.4
MATCH_TOP_K=20
BUDGET_FEASIBILITY_FACTOR=2.0

# Cron schedule for automatic ingestion (default: daily at 06:00 UTC)
INGEST_CRON=0 6 * * *

LOG_LEVEL=INFO

# Drafting agent model (configurable; default: claude-sonnet-4-6)
AGENT_MODEL=claude-sonnet-4-6
